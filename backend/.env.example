PORT=5000

# Recommended: MongoDB Atlas (free cloud database — no local install)
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas/register
# 2. Database Access → Add user with password
# 3. Network Access → Add IP Address → Allow Access from Anywhere (0.0.0.0/0) for dev
# 4. Connect → Drivers → copy connection string and replace <password> and <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/weekly-reports?retryWrites=true&w=majority

# Alternative: local MongoDB Community Server (after installing from mongodb.com)
# MONGODB_URI=mongodb://127.0.0.1:27017/weekly-reports

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# AI Assistant (Ollama — optional, free, runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
